#include <stdio.h>

void mergesort(int a[], int l, int r){
    int i, j, k, m, temp[100];

    if(l < r){
        m = (l + r) / 2;

        mergesort(a, l, m);
        mergesort(a, m+1, r);

        i = l;
        j = m + 1;
        k = l;

        while(i <= m && j <= r){
            if(a[i] < a[j])
                temp[k++] = a[i++];
            else
                temp[k++] = a[j++];
        }

        while(i <= m)
            temp[k++] = a[i++];

        while(j <= r)
            temp[k++] = a[j++];

        for(i = l; i <= r; i++)
            a[i] = temp[i];
    }
}

int main(){
    int n, a[100];

    scanf("%d", &n);

    for(int i = 0; i < n; i++)
        scanf("%d", &a[i]);

    mergesort(a, 0, n-1);

    for(int i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
